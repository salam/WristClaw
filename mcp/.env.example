# Local dev: bind to all interfaces.
# BIND_ADDR=0.0.0.0
# HOST_PORT=8000

# objex (production): bind to loopback so apache reverse-proxies /mcp.
# BIND_ADDR=127.0.0.1
# HOST_PORT=8081

# How the MCP container reaches the relay's /health endpoint. The default
# uses the relay container's docker-compose service name on the shared
# 'relay_default' network. If the MCP runs outside docker, set this to
# http://127.0.0.1:8080/health.
# RELAY_HEALTH_URL=http://wristclaw-relay:8080/health
