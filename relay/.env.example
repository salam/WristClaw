# Container internal listen port (rarely needs changing)
PORT=8080

# Local dev defaults — relay listens on all interfaces.
# BIND_ADDR=0.0.0.0
# HOST_PORT=8080

# objex (production, shared host with apache) — bind to loopback so apache
# reverse-proxies wss://wristclaw.app/ws to ws://127.0.0.1:8080/ws.
# BIND_ADDR=127.0.0.1
# HOST_PORT=8080

# TLS is handled by the reverse proxy (apache on objex; Caddy/Fly.io if
# deploying elsewhere). The relay itself only speaks plaintext WS.
